# ========================================
# QuantViz V2 环境变量配置
# ========================================

# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置（PostgreSQL）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quantviz
DB_USER=postgres
DB_PASSWORD=your_password_here

# 定时任务
ENABLE_SCHEDULER=false

# 日志级别
LOG_LEVEL=info
